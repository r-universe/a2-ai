[submodule ".registry"]
	path = .registry
	url = https://github.com/a2-ai/a2-ai.r-universe.dev
	branch = HEAD
[submodule "blake3r"]
	path = blake3r
	url = https://github.com/a2-ai/blake3r
[submodule "dvs"]
	path = dvs
	url = https://github.com/a2-ai/dvs
[submodule "ghqc"]
	path = ghqc
	url = https://github.com/a2-ai/ghqc
[submodule "osinfo"]
	path = osinfo
	url = https://github.com/a2-ai/osinfo
[submodule "pkgpub"]
	path = pkgpub
	url = https://github.com/a2-ai/pkgpub
[submodule "presentifyr"]
	path = presentifyr
	url = https://github.com/a2-ai/presentifyr
[submodule "pyro"]
	path = pyro
	url = https://github.com/a2-ai/pyro
[submodule "reportifyr"]
	path = reportifyr
	url = https://github.com/a2-ai/reportifyr
[submodule "scicalc"]
	path = scicalc
	url = https://github.com/a2-ai/scicalc
[submodule "slurmtools"]
	path = slurmtools
	url = https://github.com/a2-ai/slurmtools
